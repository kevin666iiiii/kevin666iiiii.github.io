{
  "compilerOptions": {
    "target": "ESNext", //打包成es5
    "module": "commonjs", // 用什么模块的规范 这里用node的commonjs规范
    "declaration": true, // 可根据项目打包成相应的规范
    "sourceMap": true, // 方便排错
    "outDir": "./dist", // 打包完成存放的目录
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["./typings.d.ts"],
    "skipLibCheck": true // 跳过对声明文件的类型检查
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["node_modules"]
}
